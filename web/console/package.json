{
  "name": "@mery/console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "lint": "biome check src",
    "format": "biome format --write src",
    "typecheck": "tsc --noEmit",
    "boundary": "depcruise src --config .dependency-cruiser.cjs",
    "unused": "knip --config knip.json",
    "e2e": "playwright test",
    "a11y": "playwright test --grep @a11y",
    "generate:api": "node scripts/generate-openapi-client.mjs",
    "check:api": "node scripts/check-generated-api-fresh.mjs",
    "check:fresh": "node scripts/check-build-fresh.mjs",
    "generate:design": "node scripts/generate-design-tokens.mjs",
    "check:design": "node scripts/check-design-fresh.mjs",
    "console-check": "pnpm lint && pnpm typecheck && pnpm test && pnpm boundary && pnpm unused && pnpm check:api && pnpm check:design && pnpm check:fresh && pnpm e2e"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-table": "^8.21.3",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.78.0",
    "tailwindcss": "^4.3.0",
    "vite": "^6.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@biomejs/biome": "^1.9.4",
    "@google/design.md": "^0.2.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "dependency-cruiser": "^16.6.0",
    "jsdom": "^25.0.1",
    "knip": "^5.39.0",
    "msw": "^2.6.8",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
